<div class="wsite-section-wrap">
	<div class="wsite-section wsite-body-section wsite-section-bg-color wsite-background-172" style="background-color: #ffffff;background-image: none;is_customized: 1;" >
		<div class="wsite-section-content">
          <div class="container">
			<div class="wsite-section-elements">
				<div><div id="136695683263666991" align="left" style="width: 100%; overflow-y: hidden;" class="wcustomhtml"><!DOCTYPE html>
<html lang="en">
<head><script src="gdpr/gdprscriptd5e4.js?buildTime=1782741641"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Portfolio Slider</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
        body { background-color: #ffffff; overflow-x: hidden; }
        .slider-container { position: relative; max-width: 100%; margin: 0 auto; padding: 20px 0; background-color: #ffffff; }
        .slider { display: flex; overflow-x: auto; scroll-behavior: smooth; scrollbar-width: none; -ms-overflow-style: none; gap: 10px; padding: 10px 20px; cursor: grab; user-select: none; background-color: #ffffff; }
        .slider::-webkit-scrollbar { display: none; }
        .slider.grabbing { cursor: grabbing; scroll-behavior: auto; }
        .slider-item { position: relative; flex: 0 0 auto; width: calc(100% / 4 - 8px); cursor: pointer; transition: opacity 0.3s; border-radius: 5px; overflow: hidden; aspect-ratio: 1 / 1; border: 1px solid #eee; }
        .slider-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 0.3s; }
        .slider-item .overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s; color: white; font-size: 10px; font-weight: normal; }
        .slider-item:hover .overlay, .slider-item.active .overlay { opacity: 1; }
        .slider-item:hover img, .slider-item.active img { opacity: 0.5; }
        .project-display { margin-top: 0; min-height: 1000px; overflow: hidden; background-color: #ffffff; position: relative; }
        .project-display::after { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 25%; background: linear-gradient(to top, rgba(255,255,255,1) 0%, rgba(255,255,255,0) 100%); pointer-events: none; z-index: 2; }
        .project-display::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 7%; background: #ffffff; pointer-events: none; z-index: 3; }
        .top-bar { position: absolute; top: 0; left: 0; width: 100%; height: 7%; background: #ffffff; z-index: 4; pointer-events: auto; }
        .project-display iframe { width: 100%; height: 1000px; border: none; display: block; position: relative; z-index: 1; }
        .loading { display: flex; justify-content: center; align-items: center; height: 1000px; font-size: 18px; color: #333; text-transform: uppercase; background-color: #ffffff; position: relative; z-index: 5; }
        @media (max-width: 768px) { .slider-item { width: calc(100% / 3 - 7px); } }
        .nav-btn { position: absolute; bottom: 20px; background-color: rgba(0,0,0,0.7); color: white; border: none; width: 30px; height: 30px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; opacity: 0.7; transition: opacity 0.3s; }
        .nav-btn:hover { opacity: 1; }
        .prev { left: 20px; }
        .next { right: 20px; }
        .project-display-container { position: relative; background-color: #ffffff; }
        .loading-top { position: absolute; top: 0; left: 0; width: 100%; height: 100px; display: flex; justify-content: center; align-items: center; font-size: 18px; color: #333; text-transform: uppercase; background-color: transparent; z-index: 5; }
    </style>
</head>
<body>
    <div class="slider-container">
        <button class="nav-btn prev">&#10094;</button>
        <div class="slider" id="imageSlider"></div>
        <button class="nav-btn next">&#10095;</button>
    </div>

    <div class="project-display-container">
        <div class="loading-top" id="loadingMessage">SELECT A PROJECT TO VIEW DETAILS</div>
        <div class="project-display" id="projectDisplay">
            <div class="top-bar"></div>
        </div>
    </div>

    <script>
        const projects = [
            {
                image: "/uploads/1/3/3/3/133351565/osama-mainshot-design-3-2026_orig.png",
                page: "/D3-2026-Osama-Esmail.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/miritte-main-shot-design-3-2026-1_orig.jpg",
                page: "/D3-2026-Mirrite-Kamel.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/mothhela-mainshot-design-3-2026-2_orig.jpg",
                page: "/D3-2026-Mothhela-Hafeth.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/maged-mainshot-design-3-2026-1_orig.jpg",
                page: "/D3-2026-Maged-Mohammad.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/amina-3-main-shot-design-3-2026-1-b_orig.jpg",
                page: "/D3-2026-Amina-Amr.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/radwa-main-shot-design-3-2026_orig.png",
                page: "/D3-2026-Radwa-Khaled.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/gasser-main-shots-design-3-2026-b_orig.jpg",
                page: "/D3-2026-Gasser-Mohammed.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/ali-panels-design-3-2026-1-mainshot_orig.jpg",
                page: "/D3-2026-Ali-Essam.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/shaza-mainshot-design-3-2026-4_orig.jpg",
                page: "/D3-2026-Shaza-Samer.html"
            }
        ];

        const slider = document.getElementById('imageSlider');
        const projectDisplay = document.getElementById('projectDisplay');
        const loadingMessage = document.getElementById('loadingMessage');
        const prevBtn = document.querySelector('.prev');
        const nextBtn = document.querySelector('.next');

        projects.forEach((project, index) => {
            const sliderItem = document.createElement('div');
            sliderItem.className = 'slider-item';
            sliderItem.dataset.index = index;
            const img = document.createElement('img');
            img.src = project.image;
            img.alt = `Project ${index + 1}`;
            const overlay = document.createElement('div');
            overlay.className = 'overlay';
            overlay.textContent = 'VIEW PROJECT';
            sliderItem.appendChild(img);
            sliderItem.appendChild(overlay);
            slider.appendChild(sliderItem);
            sliderItem.addEventListener('click', function(e) {
                if (!e.target.closest('.nav-btn')) selectProject(index);
            });
            let touchStartTime;
            sliderItem.addEventListener('touchstart', function() {
                touchStartTime = new Date().getTime();
                this.classList.add('active');
            });
            sliderItem.addEventListener('touchend', function() {
                const touchEndTime = new Date().getTime();
                if (touchEndTime - touchStartTime > 300) {
                    this.classList.remove('active');
                } else {
                    selectProject(index);
                }
            });
        });

        let isMouseDown = false, startX, scrollLeft;
        slider.addEventListener('mousedown', (e) => { isMouseDown = true; slider.classList.add('grabbing'); startX = e.pageX - slider.offsetLeft; scrollLeft = slider.scrollLeft; });
        slider.addEventListener('mouseleave', () => { isMouseDown = false; slider.classList.remove('grabbing'); });
        slider.addEventListener('mouseup', () => { isMouseDown = false; slider.classList.remove('grabbing'); });
        slider.addEventListener('mousemove', (e) => { if (!isMouseDown) return; e.preventDefault(); const x = e.pageX - slider.offsetLeft; slider.scrollLeft = scrollLeft - (x - startX) * 2; });

        function selectProject(index) {
            document.querySelectorAll('.slider-item').forEach(item => item.classList.remove('active'));
            const selectedItem = document.querySelector(`.slider-item[data-index="${index}"]`);
            selectedItem.classList.add('active');
            const scrollPosition = selectedItem.offsetLeft - (slider.offsetWidth / 2) + (selectedItem.offsetWidth / 2);
            slider.scrollTo({ left: scrollPosition, behavior: 'smooth' });
            showLoadingMessage();
            loadProjectPage(projects[index].page);
        }

        function showLoadingMessage() { loadingMessage.textContent = "LOADING..."; loadingMessage.style.display = 'flex'; }

        function loadProjectPage(url) {
            projectDisplay.innerHTML = `
                <div class="top-bar"></div>
                <iframe src="${url}" class="project-frame"
                    onload="hideLoadingMessage(); this.style.visibility='visible';"
                    style="visibility:hidden;"></iframe>`;
        }

        function hideLoadingMessage() { loadingMessage.style.display = 'none'; }
        window.hideLoadingMessage = hideLoadingMessage;

        prevBtn.addEventListener('click', function(e) { e.stopPropagation(); const w = document.querySelector('.slider-item').offsetWidth + 10; slider.scrollBy({ left: -w, behavior: 'smooth' }); });
        nextBtn.addEventListener('click', function(e) { e.stopPropagation(); const w = document.querySelector('.slider-item').offsetWidth + 10; slider.scrollBy({ left: w, behavior: 'smooth' }); });
    </script>
</body>
</html>
