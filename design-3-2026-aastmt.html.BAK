<div><div id="304105742500614824" align="left" style="width: 100%; overflow-y: hidden;" class="wcustomhtml"><!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Design Studio Team</title>
    <style>
        /* Reset and base styles */
        body {
            margin: 0;
            padding: 20px;
            font-family: 'Arial', sans-serif;
            font-weight: normal;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            background-color: #ffffff;
        }

        /* Team container - aligned to left */
        .team-container {
            text-align: left;
            margin: 0;
            padding: 0;
            width: auto;
            max-width: none;
        }

        /* Team title */
        .team-title {
            font-size: 18px;
            font-weight: bold !important;
            color: #000000;
            margin-bottom: 8px; /* Reduced from 15px */
            text-align: left;
            padding: 0;
            line-height: 1.1; /* Reduced line height */
        }

        /* Team member styles */
