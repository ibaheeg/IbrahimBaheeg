<div><div id="752143158709477650" align="inherit" style="width: 100%; overflow-y: hidden;" class="wcustomhtml"><!DOCTYPE html>
<html>
<head><script src="gdpr/gdprscriptd5e4.js?buildTime=1782741641"></script>
    <title>Image Slideshow Portfolio</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #000; font-family: Arial, sans-serif; overflow-x: hidden; }
        .weebly-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        .slideshow-hero { position: relative; width: 100%; margin: 0 auto; background: #000; z-index: 1; }
        .slideshow-container { position: relative; width: 100%; height: 0; padding-bottom: 56.25%; overflow: hidden; }
        .image-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; transition: opacity 1.5s ease-in-out; background: #000; }
        .image-container.active { opacity: 1; }
        .slideshow-image { width: 100%; height: 100%; object-fit: cover; object-position: center; }
        .click-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; cursor: pointer; pointer-events: all; }
        .loading-indicator { position: absolute; bottom: 20px; right: 20px; z-index: 3; color: white; font-size: 12px; background: rgba(0,0,0,0.5); padding: 4px 8px; border-radius: 4px; display: none; }
        .loading-indicator.active { display: block; }
        .progress-container { position: absolute; bottom: 0; left: 0; width: 100%; height: 3px; background: rgba(255,255,255,0.2); z-index: 3; }
        .progress-bar { height: 100%; background: rgba(255,255,255,0.8); width: 0%; transition: width 0.1s linear; }
        .instructions { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); z-index: 3; color: white; font-size: 11px; background: rgba(0,0,0,0.3); padding: 6px 10px; border-radius: 4px; white-space: nowrap; font-weight: normal; letter-spacing: 0.5px; }
        #header, .wsite-header { position: relative; z-index: 1000; }
        .preload-container { position: absolute; opacity: 0; width: 0; height: 0; overflow: hidden; }
    </style>
</head>
<body>
    <div class="weebly-container">
        <div class="slideshow-hero">
            <div class="slideshow-container">
                <div class="image-container active" id="imageContainer0">
                    <img src="#" alt="" class="slideshow-image" data-index="0">
                </div>
                <div class="image-container" id="imageContainer1">
                    <img src="#" alt="" class="slideshow-image" data-index="1">
                </div>
                <div class="click-overlay" id="clickOverlay"></div>
                <div class="loading-indicator" id="loadingIndicator">Loading images...</div>
                <div class="progress-container">
                    <div class="progress-bar" id="progressBar"></div>
                </div>
                <div class="instructions">Click to view details</div>
                <div class="preload-container" id="preloadContainer"></div>
            </div>
        </div>
    </div>

    <script>
        const imagesData = [
           {
                image: "/uploads/1/3/3/3/133351565/osama-mainshot-design-3-2026_orig.png",
                page: "/D3-2026-Osama-Esmail.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/miritte-main-shot-design-3-2026-1_orig.jpg",
                page: "/D3-2026-Mirrite-Kamel.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/mothhela-mainshot-design-3-2026-2_orig.jpg",
                page: "/D3-2026-Mothhela-Hafeth.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/maged-mainshot-design-3-2026-1_orig.jpg",
                page: "/D3-2026-Maged-Mohammad.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/amina-3-main-shot-design-3-2026-1-b_orig.jpg",
                page: "/D3-2026-Amina-Amr.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/radwa-main-shot-design-3-2026_orig.png",
                page: "/D3-2026-Radwa-Khaled.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/gasser-main-shots-design-3-2026-b_orig.jpg",
                page: "/D3-2026-Gasser-Mohammed.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/ali-panels-design-3-2026-1-mainshot_orig.jpg",
                page: "/D3-2026-Ali-Essam.html"
            },
            {
                image: "/uploads/1/3/3/3/133351565/shaza-mainshot-design-3-2026-4_orig.jpg",
                page: "/D3-2026-Shaza-Samer.html"
            }
        ];

        const IMAGE_DURATION = 3000;
        const FADE_DURATION = 1500;
        let currentImageIndex = 0;
        let slideshowInterval;
        let imagesLoaded = 0;
        let totalImages = imagesData.length;
        let lastUpdateTime = Date.now();
        let elapsedTime = 0;

        const clickOverlay = document.getElementById('clickOverlay');
        const loadingIndicator = document.getElementById('loadingIndicator');
        const progressBar = document.getElementById('progressBar');

        function initSlideshow() {
            loadingIndicator.classList.add('active');
            preloadImages();
            setupEventListeners();
            checkAllImagesLoaded();
        }

        function preloadImages() {
            imagesData.forEach((data, index) => {
                const img = new Image();
                img.src = data.image;
                img.onload = () => {
                    imagesLoaded++;
                    const container = document.getElementById(`imageContainer${index % 2}`);
                    const imgElement = container.querySelector('.slideshow-image');
                    imgElement.src = data.image;
                    imgElement.alt = `Project Image ${index + 1}`;
                    checkAllImagesLoaded();
                };
                img.onerror = () => {
                    imagesLoaded++;
                    checkAllImagesLoaded();
                };
                const preloadImg = img.cloneNode();
                preloadContainer.appendChild(preloadImg);
            });
        }

        function checkAllImagesLoaded() {
            if (imagesLoaded >= totalImages) {
                loadingIndicator.classList.remove('active');
                startSlideshow();
            } else {
                loadingIndicator.textContent = `Loading images... (${imagesLoaded}/${totalImages})`;
            }
        }

        function startSlideshow() {
            startInterval();
            requestAnimationFrame(updateProgressBar);
        }

        function startInterval() {
            lastUpdateTime = Date.now();
            if (slideshowInterval) clearInterval(slideshowInterval);
            slideshowInterval = setInterval(() => { nextImage(); }, IMAGE_DURATION);
        }

        function nextImage() {
            const currentContainerIndex = currentImageIndex % 2;
            const nextContainerIndex = (currentImageIndex + 1) % 2;
            currentImageIndex = (currentImageIndex + 1) % totalImages;
            const nextContainer = document.getElementById(`imageContainer${nextContainerIndex}`);
            const nextImg = nextContainer.querySelector('.slideshow-image');
            nextImg.src = imagesData[currentImageIndex].image;
            const currentContainer = document.getElementById(`imageContainer${currentContainerIndex}`);
            currentContainer.classList.remove('active');
            setTimeout(() => { nextContainer.classList.add('active'); }, 50);
            elapsedTime = 0;
            lastUpdateTime = Date.now();
        }

        function updateProgressBar() {
            const now = Date.now();
            const delta = now - lastUpdateTime;
            lastUpdateTime = now;
            elapsedTime += delta;
            const progress = Math.min((elapsedTime / IMAGE_DURATION) * 100, 100);
            progressBar.style.width = progress + '%';
            if (elapsedTime >= IMAGE_DURATION) elapsedTime = 0;
            requestAnimationFrame(updateProgressBar);
        }

        function handleImageClick() {
            window.open(imagesData[currentImageIndex].page, '_blank');
        }

        function setupEventListeners() {
            if (clickOverlay) {
                clickOverlay.addEventListener('click', handleImageClick);
            }
            const header = document.getElementById('header') || document.querySelector('.wsite-header');
            if (header) {
                header.style.position = 'relative';
                header.style.zIndex = '1000';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            initSlideshow();
            setTimeout(() => {
                const header = document.getElementById('header') || document.querySelector('.wsite-header');
                if (header) { header.style.position = 'relative'; header.style.zIndex = '1000'; }
            }, 100);
        });

        window.addEventListener('load', function() {
            const slideshowHero = document.querySelector('.slideshow-hero');
            if (slideshowHero) {
                slideshowHero.style.display = 'block';
                slideshowHero.style.visibility = 'visible';
                slideshowHero.style.opacity = '1';
            }
        });
    </script>
</body>

