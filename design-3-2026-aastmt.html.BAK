		<style>
/* ========== MAIN HEADER BAR ========== */
/* Target all possible header containers - make white */
header, .header, .site-header, .wsite-header, #header, 
.header-wrap, .wsite-header-wrap, .wsite-page-header, 
.nav-wrap, .wsite-menu-wrap, .wsite-background,
.wsite-menu, .wsite-menu-default,
.birdseye-header,
.birdseye-header .nav-wrap,
.birdseye-header .wsite-header,
.birdseye-header .header-wrap,
.birdseye-header .container {
    background-color: white !important;
    background: white !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
}

/* Remove any border/stroke/outline from header */
header, .header, .site-header, .wsite-header, #header,
.header-wrap, .wsite-header-wrap, .wsite-page-header,
.birdseye-header {
    border: 0 !important;
    border-bottom: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
}

/* Specifically target any potential borders on birdseye-header */
.birdseye-header,
.birdseye-header > div,
.birdseye-header .nav-wrap,
.birdseye-header .container {
    border: none !important;
    border-width: 0 !important;
    border-style: none !important;
    border-color: transparent !important;
    box-shadow: none !important;
    text-shadow: none !important;
    -webkit-box-shadow: none !important;
    -moz-box-shadow: none !important;
}

/* Also check for any pseudo-elements that might create borders */
.birdseye-header::before,
.birdseye-header::after,
.birdseye-header .nav-wrap::before,
.birdseye-header .nav-wrap::after {
    display: none !important;
    content: none !important;
}

/* Force white on all possible background elements */
div[class*="header"], div[class*="Header"], 
div[class*="menu"]:not(.wsite-menu-wrap), 
div[class*="nav"] {
    background-color: white !important;
    background: white !important;
    border: none !important;
}

/* If there's a background image, remove it */
header, .header, .site-header,
.birdseye-header {
    background-image: none !important;
}

/* ========== HEADER TEXT ========== */
/* Text color black */
header, .header, .site-header, .wsite-header, #header,
.header a, .header-nav a, .wsite-menu a,
.site-header a, .nav a, .wsite-menu-default a,
.wsite-menu a, .nav .wsite-menu-item a,
#wsite-nav-cart a, .wsite-search-input,
.hamburger, .menu-icon,
.birdseye-header,
.birdseye-header a,
.birdseye-header .wsite-menu a,
.birdseye-header .nav a,
.birdseye-header .hamburger,
.birdseye-header .menu-icon {
    color: black !important;
}

/* Change SVG/menu icon colors if needed */
.hamburger span, .menu-icon span,
.wsite-menu-arrow, .wsite-nav-cart,
svg, path, .icon {
    fill: black !important;
    stroke: black !important;
    color: black !important;
}

/* ========== DROPDOWN BOXES - SPECIFIC FIX ========== */
/* Dropdown container - make white */
.wsite-menu-wrap,
.birdseye-header .wsite-menu-wrap {
    background-color: transparent !important;
    background: transparent !important;
}

/* Dropdown menu - white background */
.wsite-menu, 
.wsite-menu ul,
.wsite-menu-submenu-wrap,
.birdseye-header .wsite-menu,
.birdseye-header .wsite-menu ul,
.birdseye-header .wsite-menu-submenu-wrap {
    background-color: white !important;
    background: white !important;
    border: 1px solid #f0f0f0 !important;
}

/* Dropdown items - make white */
.wsite-menu-subitem-wrap,
.wsite-menu-subitem,
.wsite-menu-subitem a,
.wsite-menu-subitem span,
.wsite-menu-title {
    background-color: white !important;
    background: white !important;
    color: black !important;
}

/* FIX: Remove the display: block !important rule that breaks animations */
/* Dropdown should be controlled by JavaScript, not forced display */
.wsite-menu[style*="display: none"] {
    display: none !important; /* Respect JavaScript hiding */
}

.wsite-menu[style*="display: block"] {
    display: block !important; /* Respect JavaScript showing */
}

/* Dropdown list items */
.wsite-menu-subitem-wrap,
.wsite-menu li,
.wsite-menu-subitem-wrap li {
    background-color: white !important;
    background: white !important;
}

/* Dropdown links */
.wsite-menu-subitem,
.wsite-menu-subitem a,
.wsite-menu a,
.wsite-menu li a {
    background-color: white !important;
    background: white !important;
    color: black !important;
}

/* Dropdown hover states */
.wsite-menu-subitem:hover,
.wsite-menu-subitem-wrap:hover,
.wsite-menu li:hover,
.wsite-menu-subitem:hover a,
.wsite-menu-subitem:hover span {
    background-color: #f8f8f8 !important;
    background: #f8f8f8 !important;
    color: black !important;
}

/* ========== DROPDOWN TEXT ========== */
/* Force text color in dropdowns */
.wsite-menu-subitem,
.wsite-menu-subitem span,
.wsite-menu-title,
.wsite-menu li,
.wsite-menu li a,
.wsite-menu li span {
    color: black !important;
}

/* ========== SPECIFIC OVERRIDES ========== */
/* Remove any black borders specifically */
.wsite-menu, .wsite-menu-wrap, .nav-wrap,
.birdseye-header .wsite-menu,
.birdseye-header .wsite-menu-wrap,
.birdseye-header .nav-wrap {
    border: none !important;
}

/* Ensure no border on active/hover states */
.wsite-menu-item:hover, .wsite-menu-item:active,
.wsite-menu-default-item:hover, .wsite-menu-default-item:active,
.wsite-menu-subitem:hover, .wsite-menu-subitem:active {
    border: none !important;
    outline: none !important;
}

/* Force override any inline styles - BUT respect display property */
div.wsite-menu-wrap[style],
ul.wsite-menu[style],
li.wsite-menu-subitem-wrap[style],
a.wsite-menu-subitem[style] {
    background-color: white !important;
    background: white !important;
    color: black !important;
    /* DO NOT override display property here */
}

/* FIX: Allow animations to work properly */
.wsite-menu {
    transition: opacity 0.3s ease, visibility 0.3s ease !important;
}

/* When hidden by JavaScript */
.wsite-menu[style*="display: none"] {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
}

/* When shown by JavaScript */
.wsite-menu[style*="display: block"] {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: all !important;
}
</style>
