<script>
jQuery(function($) {

  var birdseyeController = {
    init: function() {
      var base = this;
      $('body').checkHeaderPositioning(window, 'affix');
      base._addClasses();
      base._attachEvents();
    },

    _addClasses: function() {
      $('body').addClass('fade-in');

      $('.wsite-menu-default').find('li.wsite-menu-item-wrap').each(function(){
        var $me = $(this);
        if($me.children('.wsite-menu-wrap').length > 0) {
          $me.addClass('has-submenu');
          $('<span class="icon-caret"></span>').insertAfter($me.children('a.wsite-menu-item'));
        }
      });

      $('.wsite-menu').find('li.wsite-menu-subitem-wrap').each(function(){
        var $me = $(this);
        if($me.children('.wsite-menu-wrap').length > 0) {
          $me.addClass('has-submenu');
          $('<span class="icon-caret"></span>').insertAfter($me.children('a.wsite-menu-subitem'));
        }
      });

      $('li.wsite-menu-subitem-wrap.wsite-nav-current').parents('.wsite-menu-wrap').addClass('open');

      $('.wsite-form-sublabel').each(function(){
        var sublabel = $(this).text();
        $(this).prev('.wsite-form-input').attr('placeholder', sublabel);
      });
    },

    _checkCartItems: function() {
      if($('#wsite-mini-cart').find('li.wsite-product-item').length > 0) {
        $('body').addClass('cart-full');
      } else {
        $('body').removeClass('cart-full');
      }
    },

    _moveLogin: function() {
      var loginDetach = $('#member-login').detach();
      $('.mobile-nav .wsite-menu-default > li:last-child').after(loginDetach);
    },

    _moveFlyout: function() {
      var move = $("#wsite-menus").detach();
      $(".birdseye-header").append(move);
    },

    _attachEvents: function() {
      var base = this;

      // Hamburger toggle - event delegation, timing-proof
      $(document).on('click', '.hamburger', function(e) {
        e.preventDefault();
        $('body').toggleClass('nav-open');
      });

      // Fixed header on scroll
      $.fn.checkHeaderPositioning = function(scrollEl, scrollClass) {
        var $me = $(this);
        if (!$me.length) return;
        if($(scrollEl).scrollTop() > 50) {
          $me.addClass(scrollClass);
        } else if($(scrollEl).scrollTop() === 0) {
          $me.removeClass(scrollClass);
        }
      };

      $(window).on('scroll', function() {
        $('body').checkHeaderPositioning(window, 'affix');
      });

      // Subnav toggle
      $(document).on('click', 'li.has-submenu span.icon-caret', function() {
        var $wrap = $(this).siblings('.wsite-menu-wrap');
        $wrap.toggleClass('open');
      });

      // Move cart + login on mobile
      if ($(window).width() <= 992) {
        setTimeout(function(){
          var loginDetach = $('#member-login').detach();
          $('.mobile-nav .wsite-menu-default > li:last-child').after(loginDetach);
        }, 1200);
      }

      // Move flyout menus into header
      setTimeout(function(){
        var move = $("#wsite-menus").detach();
        $(".birdseye-header").append(move);
      }, 400);

      // Store category dropdown
      $('.wsite-com-sidebar').on('click', function(){
        $(this).toggleClass('sidebar-expanded');
      });

      $('#wsite-search-sidebar').on('click', function(){
        $(this).toggleClass('sidebar-expanded');
      });
    }
  };

  $.fn.checkHeaderPositioning = function(scrollEl, scrollClass) {
    var $me = $(this);
    if (!$me.length) return;
    if($(scrollEl).scrollTop() > 50) {
      $me.addClass(scrollClass);
    } else if($(scrollEl).scrollTop() === 0) {
      $me.removeClass(scrollClass);
    }
  };

  $(document).ready(function(){
    birdseyeController.init();
  });

});
</script>
